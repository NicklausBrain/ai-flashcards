@using BlazorBootstrap
@using My1kWordsEe.Models
@using My1kWordsEe.Models.Grammar
@using My1kWordsEe.Models.Grammar.Forms
@using My1kWordsEe.Models.Semantics

@code {
    [Parameter]
    public required EtWord EtWord { get; init; }

    [Parameter]
    public required AdjectiveForms AdjectiveForms { get; init; }

    private DegreeOfComparison CurrentDegree { get; set; } = DegreeOfComparison.Positive;

    private AdjectiveDegreeForms CurrentDegreeForms => CurrentDegree switch
    {
        DegreeOfComparison.Positive => AdjectiveForms.Positive,
        DegreeOfComparison.Comparative => AdjectiveForms.Comparative,
        DegreeOfComparison.Superlative => AdjectiveForms.Superlative,
        _ => AdjectiveForms.Positive
    };

    private void SetDegree(DegreeOfComparison degree)
    {
        CurrentDegree = degree;
    }

    private enum DegreeOfComparison { Positive, Comparative, Superlative }
}

<div class="mb-3">
    <div class="btn-group" role="group">
        <button type="button" class="btn @(CurrentDegree == DegreeOfComparison.Positive ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetDegree(DegreeOfComparison.Positive)">Positive</button>
        <button type="button" class="btn @(CurrentDegree == DegreeOfComparison.Comparative ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetDegree(DegreeOfComparison.Comparative)">Comparative</button>
        <button type="button" class="btn @(CurrentDegree == DegreeOfComparison.Superlative ? "btn-primary" : "btn-outline-primary")" @onclick="() => SetDegree(DegreeOfComparison.Superlative)">Superlative</button>
    </div>
</div>

<div class="row">
    <div class="col-auto">
        <div class="row text-center"><h4>Singular</h4></div>
        <Grid TItem="NounForm" Class="table table-hover table-bordered table-striped table-sm" Data="CurrentDegreeForms.Singular" PageSize="14" Responsive="true">
            <GridColumns>
                <GridColumn TItem="NounForm" HeaderText="Case" PropertyName="GrammaticalCase">
                    @context.GrammaticalCase
                </GridColumn>
                <GridColumn TItem="NounForm" HeaderText="Eesti" PropertyName="GrammaticalCase">
                    @AdjectiveForms.SingularQuestion(context.GrammaticalCase).Et
                </GridColumn>
                <GridColumn TItem="NounForm" HeaderText="Eesti" PropertyName="CaseForm">
                    <a href="/word/@context.CaseForm.Et">
                        @if (string.Equals(EtWord.Value, context.CaseForm.Et, StringComparison.OrdinalIgnoreCase))
                        {
                            <b>@context.CaseForm.Et</b>
                        }
                        else
                        {
                            @context.CaseForm.Et
                        }
                    </a>
                </GridColumn>
                <GridColumn TItem="NounForm" HeaderText="English" PropertyName="CaseForm">
                    @context.CaseForm.En
                </GridColumn>
            </GridColumns>
            <GridTemplates>
                <GridEmptyDataTemplate TItem="NounForm">
                    <div class="text-center">
                        <Spinner Size="SpinnerSize.Medium" />
                    </div>
                </GridEmptyDataTemplate>
            </GridTemplates>
        </Grid>
    </div>

    <div class="col-auto">
        <div class="row text-center"><h4>Plural</h4></div>
        <Grid TItem="NounForm" Class="table table-hover table-bordered table-striped table-sm" Data="CurrentDegreeForms.Plural" PageSize="14" Responsive="true">
            <GridColumns>
                <GridColumn TItem="NounForm" HeaderText="Case" PropertyName="GrammaticalCase">
                    @context.GrammaticalCase
                </GridColumn>
                <GridColumn TItem="NounForm" HeaderText="Eesti" PropertyName="GrammaticalCase">
                    @AdjectiveForms.PluralQuestion(context.GrammaticalCase).Et
                </GridColumn>
                <GridColumn TItem="NounForm" HeaderText="Eesti" PropertyName="CaseForm">
                    <a href="/word/@context.CaseForm.Et">
                        @if (string.Equals(EtWord.Value, context.CaseForm.Et, StringComparison.OrdinalIgnoreCase))
                        {
                            <b>@context.CaseForm.Et</b>
                        }
                        else
                        {
                            @context.CaseForm.Et
                        }
                    </a>
                </GridColumn>
                <GridColumn TItem="NounForm" HeaderText="English" PropertyName="CaseForm">
                    @context.CaseForm.En
                </GridColumn>
            </GridColumns>
            <GridTemplates>
                <GridEmptyDataTemplate TItem="NounForm">
                    <div class="text-center">
                        <Spinner Size="SpinnerSize.Medium" />
                    </div>
                </GridEmptyDataTemplate>
            </GridTemplates>
        </Grid>
    </div>
</div>
